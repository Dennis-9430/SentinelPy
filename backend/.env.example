# =============================================================================
# SentinelPy — Configuración de Entorno
# =============================================================================
# Copiar este archivo como .env y ajustar los valores.
#   cp .env.example .env
# =============================================================================

# ── Base de Datos ──────────────────────────────────────────────────────────
# PostgreSQL connection string (solo para ejecución local sin Docker)
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_dev@localhost:5432/sentinelpy

# Credenciales PostgreSQL (usadas por docker-compose para crear la BD)
POSTGRES_DB=sentinelpy
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev
POSTGRES_PORT=5432

# ── API ────────────────────────────────────────────────────────────────────
# Puerto donde escucha la API (mapeado al host)
API_PORT=8000

# Secreto para firmar JWT — CAMBIAR en producción
# Generar con: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Modo debug (true/false) — false en producción
DEBUG=true

# ── Admin Seed ─────────────────────────────────────────────────────────────
# Credenciales del admin que se crea automáticamente al iniciar
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Notificaciones Email ──────────────────────────────────────────────────
# Configuración SMTP para envío de alertas por email
# Gmail necesita contraseña de aplicación (no la contraseña normal)
#   https://support.google.com/accounts/answer/185833
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_TO=

# ── Notificaciones Webhook ────────────────────────────────────────────────
# URL de webhook (Slack: https://hooks.slack.com/services/...)
# Discord: https://discord.com/api/webhooks/...
WEBHOOK_URL=

# Severidad mínima para notificar (critical, high, medium, low)
NOTIFY_MIN_SEVERITY=high
